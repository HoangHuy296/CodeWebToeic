{
  "name": "ivyts-1997-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-main-stack.ps1",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File .\\scripts\\reset-main-stack.ps1",
    "logs": "docker compose --profile prod --profile dev --profile mysql logs -f nginx frontend backend-dev mysql",
    "dev:frontend": "npm run dev --workspace frontend",
    "build:backend-spring": "docker compose --profile prod build backend",
    "build:frontend": "npm run build --workspace frontend",
    "seed": "powershell -ExecutionPolicy Bypass -File .\\scripts\\seed-backend-spring.ps1",
    "cleanup:regression": "powershell -ExecutionPolicy Bypass -File .\\scripts\\cleanup-regression.ps1",
    "regression:spring-stack": "powershell -ExecutionPolicy Bypass -File .\\scripts\\regression-spring-mysql.ps1",
    "smoke:student": "powershell -ExecutionPolicy Bypass -File .\\scripts\\smoke-student-role.ps1",
    "smoke:teacher": "powershell -ExecutionPolicy Bypass -File .\\scripts\\smoke-teacher-role.ps1",
    "smoke:teacher:exercise": "powershell -ExecutionPolicy Bypass -File .\\scripts\\smoke-teacher-exercise-workspace.ps1",
    "smoke:admin": "powershell -ExecutionPolicy Bypass -File .\\scripts\\smoke-admin-role.ps1"
  }
}
